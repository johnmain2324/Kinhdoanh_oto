<!-- MODAL SỬA XE -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Sửa xe</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <form method="post" enctype="multipart/form-data" action="/AdminCar/Edit">

                    <input type="hidden" id="carId" name="Id" />

                    <div class="row g-3">

                        <div class="col-md-6">

                            <label>Tên xe</label>
                            <input type="text" id="TenXe" name="TenXe" class="form-control">

                            <label class="mt-2">Hãng xe</label>
                            <input type="text" id="HangXe" name="HangXe" class="form-control">

                            <label class="mt-2">Dòng xe</label>
                            <input type="text" id="DongXe" name="DongXe" class="form-control">

                            <label class="mt-2">Năm sản xuất</label>
                            <input type="number" id="NamSanXuat" name="NamSanXuat" class="form-control">

                            <label class="mt-2">Giá niêm yết</label>
                            <input type="number" id="GiaNiemYet" name="GiaNiemYet" class="form-control">

                            <label class="mt-2">Giá khuyến mãi</label>
                            <input type="number" id="GiaKhuyenMai" name="GiaKhuyenMai" class="form-control">

                        </div>


                        <div class="col-md-6">

                            <label>Nhiên liệu</label>
                            <input type="text" id="NhienLieu" name="NhienLieu" class="form-control">

                            <label class="mt-2">Hộp số</label>
                            <input type="text" id="HopSo" name="HopSo" class="form-control">

                            <label class="mt-2">Công suất</label>
                            <input type="text" id="CongSuat" name="CongSuat" class="form-control">

                            <label class="mt-2">Màu ngoại thất</label>
                            <input type="text" id="MauNgoaiThat" name="MauNgoaiThat" class="form-control">

                            <label class="mt-2">Số chỗ</label>
                            <input type="number" id="SoCho" name="SoCho" class="form-control">

                            <label class="mt-2">Ảnh đại diện</label>

                            <input type="file" name="ThumbnailFile" class="form-control">

                            <img id="previewImage"
                                 style="width:200px;margin-top:10px;border-radius:6px">

                        </div>

                        <div class="col-12 mt-3">

                            <label>Mô tả</label>

<textarea name="Noidung" id="editor"></textarea>

                        </div>

                    </div>

                    <div class="mt-3">
                        <button class="btn btn-success">Cập nhật</button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>


<script>

    function openEditModal(id, tenxe, hangxe, thumbnail)
    {
        document.getElementById("carId").value = id;
        document.getElementById("TenXe").value = tenxe;
        document.getElementById("HangXe").value = hangxe;

        document.getElementById("previewImage").src = thumbnail;

        var modal = new bootstrap.Modal(document.getElementById('editModal'));
        modal.show();
    }

</script>



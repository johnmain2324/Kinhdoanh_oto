@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@model IEnumerable<Kinhdoanh_oto.Admin.Models.Car>

<div class="container">

    <div class="d-flex justify-content-between mb-3">
        <h2>Quản lý kho xe</h2>

        <div>
            <a class="btn btn-primary" href="/AdminCar/Create">
                + Thêm xe mới
            </a>

            <button type="button" onclick="history.back()" class="btn btn-outline-dark ms-2">
                Quay lại
            </button>
        </div>
    </div>

    <table class="table table-bordered">

        <thead>
            <tr>
                <th>Ảnh</th>
                <th>Tên xe</th>
                <th>Hãng</th>
                <th>Giá</th>
                <th width="150">Thao tác</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var car in Model)
            {
                <tr>
                    <td>
                        <img src="@car.Thumbnail" width="120" />
                    </td>

                    <td>@car.TenXe</td>

                    <td>@car.HangXe</td>

                    <td>@String.Format("{0:N0} đ", car.GiaNiemYet)</td>

                    <td>

                        <button class="btn btn-warning btn-sm"
                                onclick="openEditModal(@car.Id,'@Html.Raw(car.TenXe)','@Html.Raw(car.HangXe)','@car.Thumbnail')">
                            Sửa
                        </button>

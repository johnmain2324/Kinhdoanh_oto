@model List<Kinhdoanh_oto.Models.Car>

<div class="container mt-5">
    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow">

                    <img src="@item.Thumbnail" class="card-img-top">

                    <div class="card-body">

                        <h5>@item.TenXe</h5>

                        <p>@String.Format("{0:N0} đ", item.GiaNiemYet)</p>

                        <a asp-controller="Muaxe"
                           asp-action="Detail"
                           asp-route-id="@item.Id"
                           class="btn btn-danger">

                            Xem xe

                        </a>

                    </div>

                </div>

            </div>
        }

    </div>
</div>